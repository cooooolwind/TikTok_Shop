# ===== 项目基础配置 =====
# 项目名称，主要用于日志标识和某些资源的命名空间
PROJECT_NAME=aigc-video-platform
# 运行环境：development (开发), production (生产), test (测试)
# 开发环境下会自动开启数据库同步和详细日志
NODE_ENV=development
# 系统时区
TZ=Asia/Shanghai

# ===== 数据库配置 (PostgreSQL) =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aigc
POSTGRES_PASSWORD=aigc_dev_2024
POSTGRES_DB=aigc_platform

# ===== Redis 配置 (用于任务队列 BullMQ 和缓存) =====
REDIS_HOST=localhost
REDIS_PORT=6379

# ===== 网络服务端口 =====
# 后端服务端口
BACKEND_PORT=3000
# 前端服务端口 (用于开发模式及 CORS 配置)
FRONTEND_PORT=5173
# API 路由前缀，如：api/v1 (不带前导斜杠)
API_PREFIX=api/v1

# ===== 火山引擎 API 配置 (请务必保护好 Key) =====
# 通用配置：若下方各服务的独立 Key 为空，系统将自动回退使用此通用 Key
VOLCANO_API_KEY=your-api-key-here
# 火山方舟(Ark) API 基础地址
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 1. Seed (文本模型，用于剧本生成、图片+视频多模态理解，以 Seed 2.0 Pro 的能力和调用格式为前提开发)
VOLCANO_TEXT_API_KEY=
VOLCANO_TEXT_BASE_URL=
VOLCANO_TEXT_ENDPOINT=ep-20260514115629-vhldw
# 文本模型计费单价 (元/1M tokens)
VOLCANO_TEXT_PRICE=0.8

# 2. Seedream (图片生成，用于分镜首帧引导，以 Seedream 4.5 的能力和调用格式为前提开发)
VOLCANO_IMAGE_API_KEY=
VOLCANO_IMAGE_BASE_URL=
VOLCANO_IMAGE_ENDPOINT=ep-20260530154257-z6jbt
# 图片生成计费单价 (元/次)
VOLCANO_IMAGE_PRICE=0.2

# 3. Seedance (生成视频，以 Seedance 1.5 Pro的能力和调用格式为前提开发)
VOLCANO_VIDEO_API_KEY=
VOLCANO_VIDEO_BASE_URL=
VOLCANO_VIDEO_ENDPOINT=ep-20260514120705-pqv86
# 视频生成计费单价 (元/次)
VOLCANO_VIDEO_PRICE=0.3

# 4. Embedding (向量化模型，用于语义搜索，支持文本/图片/视频多模态)
# 模型维度默认 2048，修改维度时需同步修改数据库 entity 的 vector 长度
VOLCANO_EMBEDDING_API_KEY=
VOLCANO_EMBEDDING_BASE_URL=
VOLCANO_EMBEDDING_ENDPOINT=
# 文本输入计费单价 (元/1M tokens)
VOLCANO_EMBEDDING_TEXT_PRICE=0.7
# 图片输入计费单价 (元/1M tokens)
VOLCANO_EMBEDDING_IMAGE_PRICE=1.8

# --- 视频生成精细化控制参数 ---
# 单个分段视频允许的最大时长(秒)， Seedance 1.5 Pro 为 4-12 秒
VOLCANO_VIDEO_MAX_DURATION=12
# 轮询视频状态的最大尝试次数，超出后任务标记为超时失败
VOLCANO_VIDEO_POLLING_MAX_ATTEMPTS=120
# 轮询状态的间隔时间(毫秒)，建议不低于 5000 (5秒) 以节省 API 配额
VOLCANO_VIDEO_POLLING_INTERVAL_MS=5000
# 创建视频生成任务失败时的最大重试次数 (针对 429 或网络波动)
VOLCANO_VIDEO_CREATE_RETRY_ATTEMPTS=3
# 重试创建任务前的等待延迟(毫秒)
VOLCANO_VIDEO_CREATE_RETRY_DELAY_MS=15000
# 调用火山 API 的 HTTP 接口超时时间(毫秒)
VOLCANO_VIDEO_FETCH_TIMEOUT_MS=60000
# 调用火山文本模型 (剧本生成/多模态理解) 的 HTTP 超时时间(毫秒)，复杂 prompt 可能需要更长响应时间
VOLCANO_CHAT_TIMEOUT_MS=180000

# ===== Mock 与调试配置 (开发环境下生效) =====
# 是否开启 Mock 模式。设为 true 时将不调用真实 AI 接口，使用模拟数据
MOCK_MODE=true
# Mock 模式下返回的模拟视频地址
MOCK_VIDEO_URL=https://interactive-examples.mdn.mozilla.net/media/cc0-videos/flower.mp4
# Mock 模式下返回的视频预览缩略图地址 (可选)
MOCK_VIDEO_THUMBNAIL_URL=
# Mock 模式下返回的 Seedream 模拟首帧图地址
MOCK_FIRST_FRAME_URL=https://example.com/mock-first-frame.png

# 是否为数据看板使用 Mock 数据。设为 false 时，看板的外部指标将请求真实的 STATISTIC_API_URL
MOCK_DASHBOARD=true
# 外部统计系统的 API 基础地址 (当 MOCK_DASHBOARD=false 时必填)
STATISTIC_API_URL=https://api.your-statistic-system.com

# ===== 认证与安全 =====
# JWT 签名密钥 (预留用于后续鉴权功能)
JWT_SECRET=dev-secret-change-in-production

# ===== 文件存储与多媒体处理 =====
# 存储驱动类型：目前仅支持 local (本地文件系统)
STORAGE_TYPE=local
# 文件上传保存的目录
UPLOAD_DIR=./uploads
# 单个图片上传限制 (字节)，默认 20MB
MAX_FILE_SIZE_IMAGE=20971520
# 单个视频上传限制 (字节)，默认 500MB
MAX_FILE_SIZE_VIDEO=524288000

# FFmpeg 路径：用于视频拼接和抽帧
# 若系统环境变量 PATH 中已包含 ffmpeg，则无需设置此项
# FFMPEG_PATH=/usr/local/bin/ffmpeg

# 前后端临时 API Key 加密传输密钥
VITE_TEMP_KEY_SECRET=your_secret_passphrase

